{
  "manifest_version": 3,
  "name": "Cookie Manager with Daily Quote",
  "version": "1.0.0",
  "description": "A powerful tool for managing website cookies with features like pinning, import/export, and real-time search.",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*/*",
    "https://translate.googleapis.com/*",
    "https://v1.hitokoto.cn/*",
    "https://api.quotable.io/*",
    "https://api.apiopen.top/*",
    "https://yijuzhan.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}