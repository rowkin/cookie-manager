{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.2.3",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "geolocation",
    "activeTab",
    "scripting"
  ],
  "incognito": "split",
  "host_permissions": [
    "*://*/*",
    "https://translate.googleapis.com/*",
    "https://v1.hitokoto.cn/*",
    "https://api.quotable.io/*",
    "https://api.apiopen.top/*",
    "https://yijuzhan.com/*",
    "https://wttr.in/*",
    "https://devapi.qweather.com/*",
    "https://api.caiyunapp.com/*",
    "https://ip-api.com/*",
    "https://ipapi.co/*",
    "https://freegeoip.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "style.css"
      ],
      "js": [
        "md5.min.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "style.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}
